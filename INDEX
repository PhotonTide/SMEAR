<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<title>SMEAR // reality trails</title>
<style>
  :root{
    --void:#050406; --line:rgba(255,255,255,.10); --dim:rgba(255,255,255,.42);
    --text:rgba(255,255,255,.86); --heat:#ff3b2f; --heat2:#ff7a1a; --cool:#7a4bff;
    --mono:"SFMono-Regular",ui-monospace,"JetBrains Mono",Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{margin:0;height:100%;background:var(--void);color:var(--text);
    font-family:var(--mono);overflow:hidden;overscroll-behavior:none}
  canvas{position:fixed;inset:0;width:100vw;height:100vh;display:block;touch-action:none}

  #gate{position:fixed;inset:0;z-index:40;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:26px;
    background:radial-gradient(120% 120% at 50% 40%,#160a16 0%,#050406 70%)}
  #gate h1{margin:0;font-size:clamp(30px,9vw,64px);letter-spacing:.34em;font-weight:600;
    text-indent:.34em;background:linear-gradient(92deg,var(--cool),var(--heat) 60%,var(--heat2));
    -webkit-background-clip:text;background-clip:text;color:transparent;
    filter:drop-shadow(0 0 24px rgba(255,59,47,.25))}
  #gate p{margin:0;max-width:330px;text-align:center;line-height:1.7;color:var(--dim);
    font-size:12.5px;letter-spacing:.06em}
  #enter{appearance:none;border:1px solid var(--line);background:rgba(255,255,255,.03);
    color:var(--text);font-family:var(--mono);font-size:13px;letter-spacing:.28em;
    padding:16px 34px;border-radius:2px;cursor:pointer;text-indent:.28em;
    transition:.25s;backdrop-filter:blur(8px)}
  #enter:hover{border-color:var(--heat);color:#fff;box-shadow:0 0 32px rgba(255,59,47,.25)}
  #enter:focus-visible{outline:2px solid var(--heat);outline-offset:3px}

  .bar{position:fixed;z-index:20;left:0;right:0;top:0;display:flex;align-items:center;
    gap:8px;padding:calc(env(safe-area-inset-top) + 12px) 12px 12px;pointer-events:none}
  .bar .grp{display:flex;gap:6px;pointer-events:auto}
  .bar .spacer{flex:1}
  button.chip{appearance:none;font-family:var(--mono);font-size:11px;letter-spacing:.12em;
    color:var(--dim);background:rgba(10,8,14,.55);border:1px solid var(--line);
    border-radius:2px;padding:9px 11px;cursor:pointer;backdrop-filter:blur(10px);
    transition:.18s;white-space:nowrap}
  button.chip:hover{color:var(--text);border-color:rgba(255,255,255,.24)}
  button.chip.on{color:#fff;border-color:var(--heat);
    box-shadow:inset 0 0 0 1px rgba(255,59,47,.35),0 0 18px rgba(255,59,47,.15)}
  button.chip:focus-visible{outline:2px solid var(--heat);outline-offset:2px}
  #rec{width:44px;height:44px;border-radius:50%;padding:0;display:grid;place-items:center}
  #rec .dot{width:16px;height:16px;border-radius:50%;background:var(--heat);transition:.2s}
  #rec.recording{border-color:var(--heat)}
  #rec.recording .dot{border-radius:3px;width:14px;height:14px;animation:pulse 1.1s ease-in-out infinite}
  @keyframes pulse{50%{opacity:.35}}
  #timer{font-size:11px;letter-spacing:.14em;color:var(--heat);pointer-events:none;
    align-self:center;min-width:44px;opacity:0;transition:.2s}
  #timer.show{opacity:1}

  .rail{position:fixed;z-index:20;left:0;right:0;
    bottom:calc(env(safe-area-inset-bottom) + 76px);display:flex;gap:6px;overflow-x:auto;
    padding:0 12px;pointer-events:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
  .rail::-webkit-scrollbar{display:none}

  #panel{position:fixed;z-index:20;bottom:calc(env(safe-area-inset-bottom) + 12px);
    left:50%;transform:translateX(-50%);width:calc(100% - 24px);max-width:660px;
    background:rgba(8,6,12,.72);border:1px solid var(--line);border-radius:6px;
    backdrop-filter:blur(16px);padding:14px 14px 6px;display:none;
    grid-template-columns:1fr 1fr;gap:12px 20px}
  #panel.open{display:grid}
  .ctl{display:flex;flex-direction:column;gap:6px}
  .ctl label{display:flex;justify-content:space-between;font-size:10.5px;letter-spacing:.1em;color:var(--dim)}
  .ctl label b{color:var(--text);font-weight:500}
  input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:2px;
    background:rgba(255,255,255,.16);border-radius:2px;outline:none;margin:6px 0}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;
    border-radius:50%;background:var(--heat);cursor:pointer;
    box-shadow:0 0 12px rgba(255,59,47,.5);border:2px solid #150a10}
  input[type=range]::-moz-range-thumb{width:16px;height:16px;border-radius:50%;
    background:var(--heat);cursor:pointer;border:2px solid #150a10}
  input[type=range]:focus-visible{outline:2px solid var(--heat);outline-offset:6px}

  #toast{position:fixed;z-index:30;left:50%;bottom:calc(env(safe-area-inset-bottom) + 88px);
    transform:translateX(-50%);background:rgba(8,6,12,.9);border:1px solid var(--heat);
    color:#fff;font-size:11px;letter-spacing:.1em;padding:10px 16px;border-radius:3px;
    opacity:0;transition:.3s;pointer-events:none;text-align:center;max-width:88vw}
  #toast.show{opacity:1}
  input[type=file]{display:none}
</style>
</head>
<body>
<canvas id="gl"></canvas>

<div class="bar">
  <div class="grp">
    <button class="chip on" id="srcCam">CAM</button>
    <button class="chip" id="flip">FLIP</button>
    <button class="chip" id="srcFile">FILE</button>
  </div>
  <div class="spacer"></div>
  <span id="timer">0:00</span>
  <div class="grp">
    <button class="chip" id="rec"><span class="dot"></span></button>
    <button class="chip" id="tune">TUNE</button>
  </div>
</div>

<div class="rail" id="rail"></div>
<div id="panel"></div>
<div id="toast"></div>
<input type="file" id="file" accept="video/*" />

<div id="gate">
  <h1>SMEAR</h1>
  <p>reality trails. the moving figure leaves fading afterimages of itself along its path, stamped where it was. tap to wake the camera, then record and export straight to your camera roll.</p>
  <button id="enter">ENTER</button>
</div>

<video id="video" playsinline muted autoplay style="display:none"></video>

<script>
/* ============================================================
   SMEAR // reality trails  (afterimage build)
   in-place decay + optical-flow directional streak + hue-by-age
   ============================================================ */
const cvs=document.getElementById('gl');
const gl=cvs.getContext('webgl2',{preserveDrawingBuffer:false,antialias:false,alpha:false});
const video=document.getElementById('video');
if(!gl){document.getElementById('gate').innerHTML=
  '<p style="color:#ff3b2f;max-width:300px;text-align:center;line-height:1.7">this browser has no WebGL2. open in Safari or Chrome.</p>';}

const extF=gl.getExtension('EXT_color_buffer_float')||gl.getExtension('EXT_color_buffer_half_float');
gl.getExtension('OES_texture_float_linear');
let HALF=!!extF;

/* ---------- shaders ---------- */
const VS=`#version 300 es
in vec2 aPos; out vec2 vUv;
void main(){ vUv=aPos*0.5+0.5; gl_Position=vec4(aPos,0.,1.); }`;

const COMMON=`
float luma(vec3 c){ return dot(c,vec3(0.299,0.587,0.114)); }
float hash(vec2 p){ return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453); }
vec3 hueRot(vec3 c,float a){ const vec3 k=vec3(0.57735);
  float ca=cos(a); return c*ca+cross(k,c)*sin(a)+k*dot(k,c)*(1.0-ca); }
`;

/* afterimage: old paint fades in place, moving figure stamps new paint on top.
   the only movement of the trail is a small bounded streak along the true
   optical-flow direction, so it reads as a comet tail, never a drift.        */
const DYE=`#version 300 es
precision highp float;
in vec2 vUv; out vec4 frag;
uniform sampler2D uDye,uCam,uPrev;
uniform vec2 uRes;
uniform float uTime,uDecay,uSens,uSmear,uMelt,uMosh,uBlock,uHue,uMirror;
`+COMMON+`
void main(){
  vec2 uv=vUv; vec2 cuv=uv; if(uMirror>0.5) cuv.x=1.0-cuv.x;
  vec2 tx=1.0/uRes;

  vec3 cam =texture(uCam ,cuv).rgb;
  vec3 prev=texture(uPrev,cuv).rgb;
  float It=luma(cam)-luma(prev);
  float motion=smoothstep(uSens,uSens+0.08, abs(It));

  /* true optical-flow direction (brightness constancy), bounded */
  float Ix=luma(texture(uCam,cuv+vec2(tx.x,0.)).rgb)-luma(texture(uCam,cuv-vec2(tx.x,0.)).rgb);
  float Iy=luma(texture(uCam,cuv+vec2(0.,tx.y)).rgb)-luma(texture(uCam,cuv-vec2(0.,tx.y)).rgb);
  vec2 flow=-It*vec2(Ix,Iy)/(Ix*Ix+Iy*Iy+1e-3);
  vec2 fdir = length(flow)>1e-5 ? normalize(flow) : vec2(0.0);

  /* read the OLD afterimage: mostly in place, streaked a few texels along motion */
  vec2 ruv=uv;
  ruv += fdir * uSmear * 3.0 * tx * (0.4+motion);      // bounded streak, stays put
  vec2 c=uv-0.5; ruv=0.5+(ruv-0.5)*(1.0-uMelt*0.02);   // optional slow radial melt

  /* datamosh macroblock displacement */
  vec2 block=floor(uv*uBlock)/uBlock;
  float bh=hash(block+floor(uTime*8.0)*0.137);
  vec2 bdir=normalize(vec2(bh-0.5,hash(block.yx)-0.5)+1e-4);
  float bmot=smoothstep(uSens,uSens+0.1, abs(luma(texture(uCam,block).rgb)-luma(texture(uPrev,block).rgb)));
  ruv -= bdir*bmot*uMosh*0.05*step(0.55,hash(block+0.7));

  vec3 old=texture(uDye,ruv).rgb * uDecay;
  vec3 D=max(old, cam*motion);          // stamp the moving figure into the trail
  D=hueRot(D, uHue*0.04);               // older paint has cycled further in hue
  frag=vec4(D,1.0);
}`;

const COMP=`#version 300 es
precision highp float;
in vec2 vUv; out vec4 frag;
uniform sampler2D uCam,uDye;
uniform vec2 uRes; uniform float uTime,uAber,uThermal,uShatter,uScan,uMirror,uGrain,uBase;
`+COMMON+`
vec3 thermal(float t){ t=clamp(t,0.,1.);
  vec3 c0=vec3(0.02,0.,0.08),c1=vec3(0.18,0.02,0.38),c2=vec3(0.76,0.07,0.32),
       c3=vec3(0.99,0.34,0.12),c4=vec3(1.,0.80,0.28),c5=vec3(1.,1.,0.94);
  if(t<0.2) return mix(c0,c1,t/0.2);
  if(t<0.4) return mix(c1,c2,(t-0.2)/0.2);
  if(t<0.6) return mix(c2,c3,(t-0.4)/0.2);
  if(t<0.8) return mix(c3,c4,(t-0.6)/0.2);
  return mix(c4,c5,(t-0.8)/0.2); }
void main(){
  vec2 uv=vUv; vec2 cuv=uv; if(uMirror>0.5) cuv.x=1.0-cuv.x;
  float line=floor(uv.y*uRes.y*0.5);
  float jit=(hash(vec2(line,floor(uTime*20.0)))-0.5)*uShatter*0.05;
  vec2 suv=uv+vec2(jit,0.0);
  vec2 dir=uv-0.5; float ab=uAber*0.02;
  vec3 tr;
  tr.r=texture(uDye,suv+dir*ab).r;
  tr.g=texture(uDye,suv).g;
  tr.b=texture(uDye,suv-dir*ab).b;
  tr=mix(tr, thermal(luma(tr)*1.4), uThermal);
  vec3 base;
  base.r=texture(uCam,cuv+dir*ab*0.4).r;
  base.g=texture(uCam,cuv).g;
  base.b=texture(uCam,cuv-dir*ab*0.4).b;
  base*=uBase;
  vec3 col=1.0-(1.0-base)*(1.0-tr);
  col*=1.0-uScan*0.5*(0.5+0.5*sin(uv.y*uRes.y*1.5));
  col+=(hash(uv+fract(uTime))-0.5)*uGrain*0.15;
  frag=vec4(col,1.0);
}`;

/* ---------- gl helpers ---------- */
function sh(t,s){const o=gl.createShader(t);gl.shaderSource(o,s);gl.compileShader(o);
  if(!gl.getShaderParameter(o,gl.COMPILE_STATUS))console.error(gl.getShaderInfoLog(o));return o;}
function prog(v,f){const p=gl.createProgram();gl.attachShader(p,sh(gl.VERTEX_SHADER,v));
  gl.attachShader(p,sh(gl.FRAGMENT_SHADER,f));gl.linkProgram(p);
  if(!gl.getProgramParameter(p,gl.LINK_STATUS))console.error(gl.getProgramInfoLog(p));return p;}
const pDye=prog(VS,DYE), pComp=prog(VS,COMP);

const quad=gl.createBuffer();
gl.bindBuffer(gl.ARRAY_BUFFER,quad);
gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
function bindQuad(p){const l=gl.getAttribLocation(p,'aPos');
  gl.bindBuffer(gl.ARRAY_BUFFER,quad);gl.enableVertexAttribArray(l);
  gl.vertexAttribPointer(l,2,gl.FLOAT,false,0,0);}
function tex(){const t=gl.createTexture();gl.bindTexture(gl.TEXTURE_2D,t);
  gl.texParameteri(gl.TEXTURE_2D,gl.TEXTURE_MIN_FILTER,gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D,gl.TEXTURE_MAG_FILTER,gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D,gl.TEXTURE_WRAP_S,gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D,gl.TEXTURE_WRAP_T,gl.CLAMP_TO_EDGE);return t;}

let W=1,H=1;
let camTex=[tex(),tex()], camIdx=0;
let dyeTex=[tex(),tex()], dyeFbo=[gl.createFramebuffer(),gl.createFramebuffer()], dyeSrc=0;

function allocFloat(t){gl.bindTexture(gl.TEXTURE_2D,t);
  gl.texImage2D(gl.TEXTURE_2D,0,gl.RGBA16F,W,H,0,gl.RGBA,gl.HALF_FLOAT,null);}
function alloc8(t){gl.bindTexture(gl.TEXTURE_2D,t);
  gl.texImage2D(gl.TEXTURE_2D,0,gl.RGBA,W,H,0,gl.RGBA,gl.UNSIGNED_BYTE,null);}
function allocTargets(){
  for(let i=0;i<2;i++){
    HALF?allocFloat(dyeTex[i]):alloc8(dyeTex[i]);
    gl.bindFramebuffer(gl.FRAMEBUFFER,dyeFbo[i]);
    gl.framebufferTexture2D(gl.FRAMEBUFFER,gl.COLOR_ATTACHMENT0,gl.TEXTURE_2D,dyeTex[i],0);
    if(gl.checkFramebufferStatus(gl.FRAMEBUFFER)!==gl.FRAMEBUFFER_COMPLETE && HALF){
      HALF=false; gl.bindFramebuffer(gl.FRAMEBUFFER,null); return allocTargets();
    }
    gl.clearColor(0,0,0,1); gl.clear(gl.COLOR_BUFFER_BIT);
  }
  for(let i=0;i<2;i++) alloc8(camTex[i]);
  gl.bindFramebuffer(gl.FRAMEBUFFER,null);
}
function resize(){
  const dpr=Math.min(window.devicePixelRatio||1,2);
  let w=cvs.clientWidth*dpr,h=cvs.clientHeight*dpr;
  const maxEdge=1600,m=Math.max(w,h);
  if(m>maxEdge){const s=maxEdge/m;w*=s;h*=s;}
  W=Math.max(2,Math.round(w));H=Math.max(2,Math.round(h));
  cvs.width=W;cvs.height=H;allocTargets();
}
window.addEventListener('resize',resize);

/* ---------- params ---------- */
const P={ decay:0.95, sens:0.05, smear:0.4, melt:0.15, mosh:0.4, block:24,
  aber:0.5, thermal:0.3, hue:0.0, shatter:0.15, scan:0.12, base:0.58, grain:0.22 };
const u=(p,n,v)=>gl.uniform1f(gl.getUniformLocation(p,n),v);

/* ---------- render ---------- */
let t0=performance.now(), mirror=0, ready=false;
function frame(now){
  requestAnimationFrame(frame);
  if(!ready||video.readyState<2) return;
  const time=(now-t0)/1000, cur=camIdx, prev=1-camIdx;

  gl.bindTexture(gl.TEXTURE_2D,camTex[cur]);
  gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL,true);
  try{ gl.texImage2D(gl.TEXTURE_2D,0,gl.RGBA,gl.RGBA,gl.UNSIGNED_BYTE,video); }catch(e){}
  gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL,false);

  const dyeDst=1-dyeSrc;

  /* dye / afterimage */
  gl.bindFramebuffer(gl.FRAMEBUFFER,dyeFbo[dyeDst]); gl.viewport(0,0,W,H);
  gl.useProgram(pDye); bindQuad(pDye);
  gl.activeTexture(gl.TEXTURE0);gl.bindTexture(gl.TEXTURE_2D,dyeTex[dyeSrc]);gl.uniform1i(gl.getUniformLocation(pDye,'uDye'),0);
  gl.activeTexture(gl.TEXTURE1);gl.bindTexture(gl.TEXTURE_2D,camTex[cur]);gl.uniform1i(gl.getUniformLocation(pDye,'uCam'),1);
  gl.activeTexture(gl.TEXTURE2);gl.bindTexture(gl.TEXTURE_2D,camTex[prev]);gl.uniform1i(gl.getUniformLocation(pDye,'uPrev'),2);
  gl.uniform2f(gl.getUniformLocation(pDye,'uRes'),W,H);
  u(pDye,'uTime',time);u(pDye,'uDecay',P.decay);u(pDye,'uSens',P.sens);u(pDye,'uSmear',P.smear);
  u(pDye,'uMelt',P.melt);u(pDye,'uMosh',P.mosh);u(pDye,'uBlock',P.block);u(pDye,'uHue',P.hue);u(pDye,'uMirror',mirror);
  gl.drawArrays(gl.TRIANGLES,0,3);

  /* composite */
  gl.bindFramebuffer(gl.FRAMEBUFFER,null); gl.viewport(0,0,W,H);
  gl.useProgram(pComp); bindQuad(pComp);
  gl.activeTexture(gl.TEXTURE0);gl.bindTexture(gl.TEXTURE_2D,camTex[cur]);gl.uniform1i(gl.getUniformLocation(pComp,'uCam'),0);
  gl.activeTexture(gl.TEXTURE1);gl.bindTexture(gl.TEXTURE_2D,dyeTex[dyeDst]);gl.uniform1i(gl.getUniformLocation(pComp,'uDye'),1);
  gl.uniform2f(gl.getUniformLocation(pComp,'uRes'),W,H);
  u(pComp,'uTime',time);u(pComp,'uAber',P.aber);u(pComp,'uThermal',P.thermal);u(pComp,'uShatter',P.shatter);
  u(pComp,'uScan',P.scan);u(pComp,'uMirror',mirror);u(pComp,'uGrain',P.grain);u(pComp,'uBase',P.base);
  gl.drawArrays(gl.TRIANGLES,0,3);

  dyeSrc=dyeDst; camIdx=prev;
}
requestAnimationFrame(frame);

/* ---------- sources ---------- */
let stream=null, facing='environment', usingFile=false;
async function startCam(){
  usingFile=false;
  if(stream) stream.getTracks().forEach(t=>t.stop());
  try{
    stream=await navigator.mediaDevices.getUserMedia({
      video:{facingMode:facing,width:{ideal:1280},height:{ideal:720}},audio:false});
    video.srcObject=stream; video.loop=false; video.muted=true; await video.play();
    mirror=facing==='user'?1:0; resize(); ready=true;
    setChip('srcCam',true); setChip('srcFile',false);
  }catch(e){ toast('camera blocked. check permissions.'); }
}
function useFile(f){
  usingFile=true;
  if(stream) stream.getTracks().forEach(t=>t.stop());
  video.srcObject=null; video.src=URL.createObjectURL(f);
  video.loop=true; video.muted=true; mirror=0; video.play(); resize(); ready=true;
  setChip('srcCam',false); setChip('srcFile',true);
}

/* ---------- recording ---------- */
let recorder=null,chunks=[],recStart=0,recTimer=null;
function pickMime(){
  const c=['video/mp4;codecs=avc1.42E01E','video/mp4;codecs=avc1','video/mp4',
           'video/webm;codecs=vp9','video/webm;codecs=vp8','video/webm'];
  for(const m of c){ if(window.MediaRecorder&&MediaRecorder.isTypeSupported(m)) return m; }
  return '';
}
function startRec(){
  const cs=cvs.captureStream(60), mime=pickMime();
  try{ recorder=new MediaRecorder(cs,mime?{mimeType:mime,videoBitsPerSecond:12e6}:{}); }
  catch(e){ toast('recording not supported here'); return; }
  chunks=[];
  recorder.ondataavailable=e=>{ if(e.data.size) chunks.push(e.data); };
  recorder.onstop=()=>{
    const type=recorder.mimeType||mime||'video/webm';
    const ext=type.includes('mp4')?'mp4':'webm';
    const blob=new Blob(chunks,{type}), url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=`smear_${Date.now()}.${ext}`;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(()=>URL.revokeObjectURL(url),4000);
    toast(ext==='mp4'?'saved · mp4 ready for camera roll':'saved · webm (mp4 only on iphone)');
  };
  recorder.start(); recStart=performance.now();
  document.getElementById('rec').classList.add('recording');
  document.getElementById('timer').classList.add('show');
  recTimer=setInterval(()=>{const s=Math.floor((performance.now()-recStart)/1000);
    document.getElementById('timer').textContent=`${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;},500);
}
function stopRec(){
  if(recorder&&recorder.state!=='inactive') recorder.stop();
  clearInterval(recTimer);
  document.getElementById('rec').classList.remove('recording');
  document.getElementById('timer').classList.remove('show');
}

/* ---------- presets ---------- */
const PRESETS={
  SMEAR:   {decay:.95, sens:.045,smear:.6, melt:.15,mosh:.2, block:24,aber:.4, thermal:0,  hue:0, shatter:.08,scan:.1, base:.58,grain:.2},
  ECHO:    {decay:.975,sens:.04, smear:.12,melt:.05,mosh:.1, block:24,aber:.5, thermal:0,  hue:0, shatter:.06,scan:.08,base:.55,grain:.2},
  DATAMOSH:{decay:.945,sens:.05, smear:.25,melt:.1, mosh:.9, block:16,aber:.6, thermal:.2, hue:0, shatter:.25,scan:.12,base:.6, grain:.35},
  THERMAL: {decay:.96, sens:.045,smear:.4, melt:.12,mosh:.3, block:22,aber:.4, thermal:.92,hue:0, shatter:.12,scan:.1, base:.34,grain:.22},
  SHATTER: {decay:.94, sens:.06, smear:.35,melt:.1, mosh:.4, block:20,aber:.9, thermal:.15,hue:0, shatter:.7, scan:.18,base:.55,grain:.4},
  ACID:    {decay:.975,sens:.04, smear:.5, melt:.12,mosh:.25,block:26,aber:.8, thermal:0,  hue:1, shatter:.2, scan:.1, base:.42,grain:.25}
};
function applyPreset(n){ Object.assign(P,PRESETS[n]);
  document.querySelectorAll('.rail .chip').forEach(c=>c.classList.toggle('on',c.dataset.p===n));
  buildPanel();
}

/* ---------- UI ---------- */
const rail=document.getElementById('rail');
Object.keys(PRESETS).forEach((n,i)=>{const b=document.createElement('button');
  b.className='chip'+(i===0?' on':'');b.textContent=n;b.dataset.p=n;
  b.onclick=()=>applyPreset(n);rail.appendChild(b);});

const FIELDS=[
  ['decay','persistence',0.85,0.995,0.005],
  ['sens','sensitivity',0.01,0.2,0.005],
  ['smear','streak',0,1.5,0.01],
  ['melt','melt',0,1,0.01],
  ['mosh','datamosh',0,1.5,0.01],
  ['block','block size',6,60,1],
  ['aber','chromatic',0,1.5,0.01],
  ['thermal','thermal',0,1,0.01],
  ['hue','hue cycle',0,1,0.01],
  ['shatter','shatter',0,1,0.01],
  ['scan','scanlines',0,0.6,0.01],
  ['base','base image',0,1,0.01],
  ['grain','grain',0,1,0.01]
];
const panel=document.getElementById('panel');
function buildPanel(){ panel.innerHTML='';
  FIELDS.forEach(([k,lab,mn,mx,st])=>{
    const w=document.createElement('div');w.className='ctl';
    const l=document.createElement('label');
    l.innerHTML=`<span>${lab}</span><b>${Number(P[k]).toFixed(st<1?2:0)}</b>`;
    const r=document.createElement('input');r.type='range';r.min=mn;r.max=mx;r.step=st;r.value=P[k];
    r.oninput=()=>{P[k]=parseFloat(r.value);l.querySelector('b').textContent=Number(P[k]).toFixed(st<1?2:0);};
    w.append(l,r);panel.appendChild(w);
  });
}
buildPanel();

function setChip(id,on){document.getElementById(id).classList.toggle('on',on);}
document.getElementById('tune').onclick=e=>{panel.classList.toggle('open');
  e.currentTarget.classList.toggle('on',panel.classList.contains('open'));};
document.getElementById('rec').onclick=()=>{ if(recorder&&recorder.state==='recording') stopRec(); else startRec(); };
document.getElementById('flip').onclick=()=>{ if(usingFile){facing='environment';startCam();return;}
  facing=facing==='user'?'environment':'user';startCam();};
document.getElementById('srcCam').onclick=()=>startCam();
document.getElementById('srcFile').onclick=()=>document.getElementById('file').click();
document.getElementById('file').onchange=e=>{ if(e.target.files[0]) useFile(e.target.files[0]); };

let toastT;
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');
  clearTimeout(toastT);toastT=setTimeout(()=>t.classList.remove('show'),2800);}

document.getElementById('enter').onclick=()=>{
  document.getElementById('gate').style.display='none'; resize(); startCam();
};
</script>
</body>
</html>
